[sub_resource type="GDScript" id="GDScript_y0vbl"]
script/source = "extends Panel

signal sceneTriggered()

@export var player : AnimationPlayer
@export var button : Button
@export var sound : AudioStreamPlayer

var sceneHasTriggered : bool = false


func _ready() -> void:
	Characters.all_dice_spent.connect(_on_all_dice_spent)
	SkillDice.dice_rerolled.connect(_on_dice_rerolled)
	button.pressed.connect(_on_pressed)


func _on_pressed() -> void:
	if not sceneHasTriggered:
		var diceSpent = Characters.check_all_dice_spent()
		if not diceSpent:
			sceneTriggered.emit()
			player.play(\"Grab\")
			sceneHasTriggered = true
			button.disabled = true
			return
	TurnSystem.end_round()
	sound.play()


func _on_all_dice_spent() -> void:
	button.disabled = false
	if sceneHasTriggered:
		player.play(\"Give\")


func _on_dice_rerolled() -> void:
	player.play(\"RESET\") # TODO: have Dispatch return the button
	if sceneHasTriggered:
		button.disabled = true
		player.play(\"Grab\")
"

