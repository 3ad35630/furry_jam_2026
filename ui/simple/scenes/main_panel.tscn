[sub_resource type="GDScript" id="GDScript_6bu6o"]
script/source = "extends TextureButton

func _ready() -> void:
	Modes.gameplay_mode_changed.connect(on_mode_changed)

func on_mode_changed(mode : Enums.GameplayMode) -> void:
	if mode == Enums.GameplayMode.NARRATIVE:
		hide()
	else:
		show()
"

[sub_resource type="StyleBoxEmpty" id="StyleBoxEmpty_36p3s"]

[sub_resource type="GDScript" id="GDScript_y0vbl"]
script/source = "extends Panel

signal sceneTriggered()

@export var player : AnimationPlayer
@export var button : TextureButton
@export var sound : AudioStreamPlayer

var sceneHasTriggered : bool = false

## Dispatch will not automatically steal the button on successive turns
const resetTrigger : bool = true

## path to default narrative with Dispatch interaction
## set to '' to disable the narrative event (but not the button-stealing)
const narrativePath : String = ''#dispatch_scold'
# paths to character-specific Dispath scoldings
# NOTE: setting a path to '' will cause narrativePath ^ to be used instead
const characterNarratives : Dictionary[String,String] = {
	'Mirabelle' : '',#dispatch_scold_mirabelle
	'Willow' : '',
	'Mittens' : ''
}


func _ready() -> void:
	Characters.all_dice_spent.connect(_on_all_dice_spent)
	SkillDice.dice_rerolled.connect(_on_dice_rerolled)
	button.pressed.connect(_on_pressed)


func _on_pressed() -> void:
	if not sceneHasTriggered:
		var diceSpent = Characters.check_all_dice_spent()
		if not diceSpent:
			sceneTriggered.emit()
			_trigger_narrative()
			player.play(\"Grab\")
			sceneHasTriggered = true
			button.disabled = true
			return
	TurnSystem.end_round()
	sound.play()


func _trigger_narrative() -> void:
	var path : String = narrativePath
	var hasDice = Characters.get_characters_with_dice() # sort of redundant with check_all_dice_spent()
	if hasDice.size() > 0: # pick a random character to chew out
		var idx = randi_range(0,hasDice.size()-1)
		var c = hasDice[idx]
		if c.name in characterNarratives.keys(): # probably not ideal?
			path = characterNarratives[c.name]
	if path.is_empty(): # in case we don't have keys for the other characters
		path = narrativePath
	if not path.is_empty():
		NarrativeSystem.start_narrative(path)


func _on_all_dice_spent() -> void:
	button.disabled = false
	if sceneHasTriggered:
		player.play(\"Give\")


func _on_dice_rerolled() -> void:
	player.play(\"RESET\") # TODO: have Dispatch return the button
	if resetTrigger:
		sceneHasTriggered = false
	if sceneHasTriggered:
		button.disabled = true
		player.play(\"Grab\")
"

