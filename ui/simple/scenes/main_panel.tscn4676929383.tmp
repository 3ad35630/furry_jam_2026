	SkillDice.roll_all_dice()
"

[sub_resource type="GDScript" id="GDScript_gof1d"]
resource_name = "mode_label"
script/source = "extends Label

func _ready() -> void:
	Modes.gameplay_mode_changed.connect(on_gameplay_mode_changed)
	update()
	
func on_gameplay_mode_changed(_new_mode : Enums.GameplayMode) -> void:
	update()

func update() -> void:
	match Modes.current_mode:
		Enums.GameplayMode.MAP : 
			self.text = \"MODE: Map\"
		Enums.GameplayMode.LOCATION : 
			self.text = \"MODE: Location\"
		Enums.GameplayMode.NARRATIVE : 
			self.text = \"MODE: Narrative\"
		Enums.GameplayMode.CONVERSATION : 
			self.text = \"MODE: Conversation\"
"

[sub_resource type="GDScript" id="GDScript_s3n1p"]
script/source = "extends Label

func _ready() -> void:
	TurnSystem.round_started.connect(on_round_started)
	update()
	
func update():
	text = \"Round: \" + str(TurnSystem.current_round)

func on_round_started():
	update()
"

[sub_resource type="GDScript" id="GDScript_g6gw2"]
script/source = "extends Control

@export var location_control : Control
@export var map_control : Control

func _ready() -> void:
	Modes.gameplay_mode_changed.connect(on_gameplay_mode_changed)
	update()
	
func on_gameplay_mode_changed(_new_mode : Enums.GameplayMode) -> void:
	update()

func update() -> void:
	match Modes.current_mode:
		Enums.GameplayMode.MAP : 
			location_control.visible = false
			map_control.visible = true
		Enums.GameplayMode.LOCATION : 
			location_control.visible = true
			map_control.visible = false
		Enums.GameplayMode.NARRATIVE : 
			location_control.visible = false
			map_control.visible = false
		Enums.GameplayMode.CONVERSATION : 
			location_control.visible = false
			map_control.visible = false
"

[sub_resource type="GDScript" id="GDScript_k3n4s"]
script/source = "extends VBoxContainer

@export var action_container : VBoxContainer
@export var clock_container : VBoxContainer
@export var dice_container : HBoxContainer
@export var description_label : Label

@export var action_display : PackedScene
@export var clock_display : PackedScene

func _ready() -> void:
	visibility_changed.connect(on_visibility_changed)

func on_visibility_changed():
	if visible:
		update()
	else:
		clear()

func update() -> void:
	assert(Modes.current_mode == Enums.GameplayMode.LOCATION)
	assert(Modes.current_location != null)
	
	description_label.text = \"Description: \\n\" + Modes.current_location.description
	
	for action in Modes.current_location.accessible_actions:
		create_action_display(action)
	for clock in Modes.current_location.accessible_clocks:
		create_clock_display(clock)

func create_action_display(action : Action) -> void:
	assert(action_display != null)
	var new = action_display.instantiate()
	new.action = action
	new.skill_die_removed.connect(dice_container.on_skill_die_removed)
	action_container.add_child(new)

func create_clock_display(clock : Clock) -> void:
	assert(clock_display != null)
	var new = clock_display.instantiate()
	new.clock = clock
	clock.completed.connect(on_clock_completed)
	clock_container.add_child(new)
	
func on_clock_completed(_clock : Clock) -> void:
	clear()
	update()
	
func clear() -> void:
	for child in action_container.get_children():
		action_container.remove_child(child)
		child.queue_free()
	for child in clock_container.get_children():
		clock_container.remove_child(child)
		child.queue_free()
"

[sub_resource type="GDScript" id="GDScript_g746w"]
script/source = "extends Button

func _on_pressed() -> void:
	Modes.exit_location()
"

[sub_resource type="StyleBoxFlat" id="StyleBoxFlat_k3n4s"]

[sub_resource type="GDScript" id="GDScript_16uew"]
script/source = "extends VBoxContainer

func _ready() -> void:
	visibility_changed.connect(on_visibility_changed)

func on_visibility_changed():
	if visible:
		update()
	else:
		clear()

func update() -> void:
	for location in Locations.accessible_locations:
		create_button(location)

func create_button(location : Location) -> void:
	var new_button = LocationButton.new()
	new_button.location = location
	add_child(new_button)

func clear() -> void:
	for child in get_children():
		remove_child(child)
		child.queue_free()
"

[sub_resource type="GDScript" id="GDScript_6ccxr"]
script/source = "extends HBoxContainer

var hbox_dict : Dictionary[Character, HBoxContainer] = {}
@export var dice_display : PackedScene

func _ready() -> void:
	for character in Characters.characters:
		character.dice_updated.connect(update_dice_display_for_character)
		var new_hbox = HBoxContainer.new()
		add_child(new_hbox)
		hbox_dict[character] = new_hbox
		update_dice_display_for_character(character)
		
func update_dice_display_for_character(character : Character) -> void:
	for child in hbox_dict[character].get_children():
		hbox_dict[character].remove_child(child)
		child.queue_free()
	for die in character.dice_dicts:
		var new_dice_display = dice_display.instantiate()
		new_dice_display.data = die
		hbox_dict[character].add_child(new_dice_display)

func on_skill_die_removed(data):
	for display in hbox_dict[data['character']].get_children():
		if display.data['index'] == data['index']:
			display.visible = true
"

[sub_resource type="GDScript" id="GDScript_y0vbl"]
script/source = "extends Button
func _on_pressed() -> void:
	TurnSystem.end_round()
"

