[sub_resource type="GDScript" id="GDScript_c4p16"]
script/source = "extends Panel

func _ready() -> void:
	Modes.gameplay_mode_changed.connect(change_mode)

func change_mode(mode : Enums.GameplayMode) -> void:
	if mode == Enums.GameplayMode.NARRATIVE:
		show()
	else:
		hide()
"

[sub_resource type="GDScript" id="GDScript_g746w"]
script/source = "extends ScrollContainer

@export var line_widget : PackedScene
@export var button_control : Control
@export var line_container : VBoxContainer

func _ready() -> void:
	get_window().size_changed.connect(update)
	call_deferred(\"update\")
	Modes.gameplay_mode_changed.connect(change_mode)
	NarrativeSystem.continued.connect(add_line)

func update() -> void: 
	var button_y = button_control.size.y
	custom_minimum_size = Vector2(0.0, get_window().size.y - button_y)

func change_mode(mode : Enums.GameplayMode) -> void:
	if mode == Enums.GameplayMode.NARRATIVE:
		clear_lines()

func add_line(text, _tags) -> void:
	var new_line_widget = line_widget.instantiate()
	new_line_widget.line = text
	line_container.add_child(new_line_widget)

func clear_lines() -> void:
	for child in line_container.get_children():
		child.queue_free()

func scroll_to_end() -> void:
	scroll_vertical = int(get_v_scroll_bar().max_value)
"

[sub_resource type="StyleBoxFlat" id="StyleBoxFlat_16uew"]
bg_color = Color(0.76128906, 0.4103079, 0.98066896, 1)

[sub_resource type="GDScript" id="GDScript_16uew"]
script/source = "extends Button
func _on_pressed() -> void:
	if Modes.current_mode == Enums.GameplayMode.NARRATIVE:
		NarrativeSystem.advance_narrative()
"

