[sub_resource type="GDScript" id="GDScript_ivlvs"]
script/source = "extends Control

@export var skill_display : Control
@export var item_display : Control

func _on_action_panel_action_set(action: Action) -> void:
	if action is SkillAction:
		skill_display.show()
		item_display.hide()
	else:
		item_display.show()
		skill_display.hide()
"

[sub_resource type="GDScript" id="GDScript_ntd7w"]
script/source = "extends Node

# this is cludgy as hell but I do not have time to build a proper die controller
# note to self, never EVER write 'temporary' code in a game-jam

var existing_data = {}
var held_action

func _on_dice_slot_data_changed(data: Variant) -> void:
	if data.is_empty():
		if not existing_data.is_empty():
			existing_data['character'].dice_updated.emit(existing_data['character'])
	else:
		existing_data = data


func _on_action_panel_action_set(action: Action) -> void:
	if action:
		held_action = action
		held_action.action_done.connect(get_parent().clear_data)
	else:
		held_action.action_done.disconnect(get_parent().clear_data)
"

[sub_resource type="GDScript" id="GDScript_riq6c"]
script/source = "extends TextureRect
@export var type_to_texture : Dictionary[Enums.ItemTypes, Texture]

func _on_action_panel_action_set(action: Action) -> void:
	if action is ItemAction:
		texture = type_to_texture[action.item_type]
"

[sub_resource type="GDScript" id="GDScript_sqpgg"]
script/source = "extends Label

var item_type : Enums.ItemTypes
var held_action : ItemAction

func _ready() -> void:
	Inventory.inventory_modified.connect(update_inventory)

func update_inventory(item : Enums.ItemTypes) -> void:
	if item == item_type:
		update()

func update() -> void:
	text = str(Inventory.count(item_type)) + \"/\" + str(held_action.required_number)

func _on_action_panel_action_set(action: Action) -> void:
	if action is ItemAction:
		item_type = action.item_type
		held_action = action
		update()
"

[sub_resource type="GDScript" id="GDScript_16uew"]
script/source = "extends Button

var is_skill : bool
var die_data : Dictionary

@export var sound : AudioStreamPlayer

func _ready() -> void:
	Inventory.inventory_modified.connect(inventory_modified)
	
func inventory_modified(_item : Enums.ItemTypes):
	update_can_press()

func _on_action_panel_action_set(action: Action) -> void:
	if action:
		is_skill = action is SkillAction
		update_can_press()
	

func _on_pressed() -> void:
	if is_skill:
		sound.play()
		SkillDice.use_skill_die_on_action(owner.action, die_data)
	else:
		owner.action.do_action(owner.action.item_type)

func update_can_press() -> void:
	if is_skill:
		self.disabled = die_data.is_empty()
	else:
		if not owner.action:
			self.disabled = true
		else:
			self.disabled = not owner.action.can_afford_action()
		
func _on_dice_slot_data_changed(data: Variant) -> void:
	die_data = data
	update_can_press()
"

[sub_resource type="GDScript" id="GDScript_bkapc"]
script/source = "extends CenterContainer

var action_is_skilled = false

func _on_die_display_data_changed(data: Variant) -> void:
	if data and action_is_skilled:
		show()
	else:
		hide()


func _on_action_panel_action_set(action: Action) -> void:
	action_is_skilled = false
	if action is SkillAction:
		action_is_skilled = action.skill != Enums.Skills.UNDEFINED
		
"

[sub_resource type="GDScript" id="GDScript_f8umy"]
script/source = "extends VBoxContainer

signal probability_changed(pos : float, neu : float, neg : float)

func _on_die_display_data_changed(data: Variant) -> void:
	if data:
		var probabilities = owner.action.get_outcome_probabilities(data)
		probability_changed.emit(
			probabilities[Enums.EffectClasses.POSITIVE],
			probabilities[Enums.EffectClasses.NEUTRAL],
			probabilities[Enums.EffectClasses.NEGATIVE])
"

[sub_resource type="GDScript" id="GDScript_3ey2a"]
script/source = "extends Label

var is_skill_action = false
var action_is_skilled = false

func _on_dice_slot_data_changed(data: Variant) -> void:
	if is_skill_action and action_is_skilled:
		if data:
			var bonus = data['character'].get_skill(owner.action.skill)
			if bonus > 0:
				text = 'Bonus: +'+str(bonus)
			else:
				text = 'Bonus: '+str(bonus)
			visible = bonus != 0
		else:
			visible = false
	else:
		visible = false


func _on_action_panel_action_set(action: Action) -> void:
	is_skill_action = false
	action_is_skilled = false
	if action:
		if action is SkillAction:
			is_skill_action = true
			action_is_skilled = action.skill != Enums.Skills.UNDEFINED
"

[sub_resource type="GDScript" id="GDScript_jn2pm"]
script/source = "extends Label

func _on_chance_labels_probability_changed(pos: float, _neu: float, _neg: float) -> void:
	if pos:
		text = \"Pos: \" + str(pos*100)+\"%\"
		show()
	else:
		hide()
"

[sub_resource type="GDScript" id="GDScript_g746w"]
script/source = "extends Label
func _on_chance_labels_probability_changed(_pos: float, neu: float, _neg: float) -> void:
	if neu:
		text = \"Neu: \" + str(neu*100)+\"%\"
		show()
	else:
		hide()
"

[sub_resource type="GDScript" id="GDScript_s3n1p"]
script/source = "extends Label
func _on_chance_labels_probability_changed(_pos: float, _neu: float, neg: float) -> void:
	if neg:
		text = \"Neg: \" + str(neg*100)+\"%\"
		show()
	else:
		hide()
"

[sub_resource type="GDScript" id="GDScript_ix5sq"]
script/source = "extends PanelContainer

@export var timer : Timer
var stored_action : Action

func _on_action_panel_action_set(action: Action) -> void:
	if stored_action:
		stored_action.action_done.disconnect(show_results)
	if action:
		action.action_done.connect(show_results)
	stored_action = action

func show_results() -> void:
	show()
	timer.start()

func _on_timer_timeout() -> void:
	hide()
"

[sub_resource type="GDScript" id="GDScript_qgrgy"]
script/source = "extends VBoxContainer

var stored_action : Action

func _on_action_panel_action_set(action: Action) -> void:
	stored_action = action
	if action:
		action.action_done.connect(show_results)
	
func show_results():
	for child in get_children():
		child.queue_free()
	if stored_action:
		for result_string in stored_action.result_text:
			var new_label = Label.new()
			new_label.text = result_string
			new_label.autowrap_mode = TextServer.AUTOWRAP_WORD
			add_child(new_label)


func _on_hide_results_timeout() -> void:
	for child in get_children():
		child.queue_free()
"

