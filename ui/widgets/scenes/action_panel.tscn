"

[sub_resource type="GDScript" id="GDScript_ivlvs"]
script/source = "extends Control

@export var skill_display : Control
@export var item_display : Control

func _on_action_panel_action_set(action: Action) -> void:
	if action is SkillAction:
		skill_display.show()
		item_display.hide()
	else:
		item_display.show()
		skill_display.hide()
"

[sub_resource type="GDScript" id="GDScript_ntd7w"]
script/source = "extends Node

# this is cludgy as hell but I do not have time to build a proper die controller
# note to self, never EVER write 'temporary' code in a game-jam

var existing_data = {}
var held_action

func _on_dice_slot_data_changed(data: Variant) -> void:
	if data.is_empty():
		if not existing_data.is_empty():
			existing_data['character'].dice_updated.emit(existing_data['character'])
	else:
		existing_data = data


func _on_action_panel_action_set(action: Action) -> void:
	if action:
		held_action = action
		held_action.action_done.connect(get_parent().clear_data)
	else:
		held_action.action_done.disconnect(get_parent().clear_data)
"

[sub_resource type="GDScript" id="GDScript_riq6c"]
script/source = "extends TextureRect
@export var type_to_texture : Dictionary[Enums.ItemTypes, AtlasTexture]

func _on_action_panel_action_set(action: Action) -> void:
	if action is ItemAction:
		texture = type_to_texture[action.item_type]
"

