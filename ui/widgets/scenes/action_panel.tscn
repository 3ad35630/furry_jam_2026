[sub_resource type="GDScript" id="GDScript_sqpgg"]
script/source = "extends Label

var item_type : Enums.ItemTypes
var held_action : ItemAction

func _ready() -> void:
	Inventory.inventory_modified.connect(update_inventory)

func update_inventory(item : Enums.ItemTypes) -> void:
	if item == item_type:
		update()

func update() -> void:
	text = str(Inventory.count(item_type)) + \"/\" + str(held_action.required_number)

func _on_action_panel_action_set(action: Action) -> void:
	if action is ItemAction:
		item_type = action.item_type
		held_action = action
		update()
"

[sub_resource type="GDScript" id="GDScript_16uew"]
script/source = "extends Button

var is_skill : bool
var die_data : Dictionary

@export var sound : AudioStreamPlayer

func _ready() -> void:
	Inventory.inventory_modified.connect(inventory_modified)
	
func inventory_modified(_item : Enums.ItemTypes):
	update_can_press()

func _on_action_panel_action_set(action: Action) -> void:
	if action:
		is_skill = action is SkillAction
		update_can_press()
	

func _on_pressed() -> void:
	if is_skill:
		sound.play()
		SkillDice.use_skill_die_on_action(owner.action, die_data)
	else:
		owner.action.do_action(owner.action.item_type)

func update_can_press() -> void:
	if is_skill:
		self.disabled = die_data.is_empty()
	else:
		if not owner.action:
			self.disabled = true
		else:
			self.disabled = not owner.action.can_afford_action()
		
func _on_dice_slot_data_changed(data: Variant) -> void:
	die_data = data
	update_can_press()
"

[sub_resource type="GDScript" id="GDScript_bkapc"]
script/source = "extends CenterContainer

func _on_die_display_data_changed(data: Variant) -> void:
	if data:
		show()
	else:
		hide()
"

[sub_resource type="GDScript" id="GDScript_f8umy"]
script/source = "extends VBoxContainer

signal probability_changed(pos : float, neu : float, neg : float)

func _on_die_display_data_changed(data: Variant) -> void:
	if data:
		var probabilities = owner.action.get_outcome_probabilities(data)
		probability_changed.emit(
			probabilities[Enums.EffectClasses.POSITIVE],
			probabilities[Enums.EffectClasses.NEUTRAL],
			probabilities[Enums.EffectClasses.NEGATIVE])
"

[sub_resource type="GDScript" id="GDScript_3ey2a"]
script/source = "extends Label


func _on_dice_slot_data_changed(data: Variant) -> void:
	if data:
		var bonus = data['character'].get_skill(owner.action.skill)
		if bonus > 0:
			text = 'Bonus: +'+str(bonus)
		else:
			text = 'Bonus: '+str(bonus)
		visible = bonus != 0
	else:
		visible = false
"

[sub_resource type="GDScript" id="GDScript_jn2pm"]
script/source = "extends Label

func _on_chance_labels_probability_changed(pos: float, _neu: float, _neg: float) -> void:
	if pos:
		text = \"Pos: \" + str(pos*100)+\"%\"
		show()
	else:
		hide()
"

[sub_resource type="GDScript" id="GDScript_g746w"]
script/source = "extends Label
func _on_chance_labels_probability_changed(_pos: float, neu: float, _neg: float) -> void:
	if neu:
		text = \"Neu: \" + str(neu*100)+\"%\"
		show()
	else:
		hide()
"

[sub_resource type="GDScript" id="GDScript_s3n1p"]
script/source = "extends Label
func _on_chance_labels_probability_changed(_pos: float, _neu: float, neg: float) -> void:
	if neg:
		text = \"Neg: \" + str(neg*100)+\"%\"
		show()
	else:
		hide()
"

