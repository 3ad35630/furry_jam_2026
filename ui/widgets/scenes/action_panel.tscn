[sub_resource type="GDScript" id="GDScript_72w5p"]
script/source = "extends Label

func _on_action_panel_action_set(action: Action) -> void:
	if action:
		text = action.resource_name
"

[sub_resource type="GDScript" id="GDScript_wsoa6"]
script/source = "extends Label

func _on_action_panel_action_set(action: Action) -> void:
	if action:
		show()
		if action is SkillAction:
			if action.skill == Enums.Skills.UNDEFINED:
				hide()
			text = Enums.Skills.keys()[action.skill].to_lower()
		else:
			text = Enums.ItemTypes.keys()[action.item_type].to_lower()
"

