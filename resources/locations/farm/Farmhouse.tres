[sub_resource type="Resource" id="Resource_a14y6"]
resource_name = "Explore the Farm"
script = ExtResource("5_7mkxp")
positive = SubResource("Resource_j18bt")
neutral = SubResource("Resource_j18bt")
negative = SubResource("Resource_j18bt")
description = "The farmhouse is old and beautiful and the grass around it is rich and tall. A beautiful place but almost silent in a way that farms are seldom found to be. The only sound is the creak of the windmill."
access_test = SubResource("Resource_npw3c")
metadata/_custom_type_script = "uid://rfr4bn03v1jh"

