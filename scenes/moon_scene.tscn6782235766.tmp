[sub_resource type="GDScript" id="GDScript_g746w"]
script/source = "extends Node3D

@export var max_speed : int = 14
@export var accelleration : int = 10

var velocity : float = 0.0

func _process(delta: float) -> void:
	if Input.is_action_pressed(\"camera_move_left\"):
		move_left(delta)
		return
	if Input.is_action_pressed(\"camera_move_right\"):
		move_right(delta)
		return
	velocity = 0
		
func move_left(delta) -> void:
	velocity += max(-accelleration * delta, -max_speed)
	rotation.y = rotation.y + velocity

func move_right(delta) -> void:
	velocity += min(accelleration * delta, max_speed)
	rotation.y = rotation.y + velocity
	
"

[sub_resource type="GDScript" id="GDScript_d1xcf"]
script/source = "extends Node3D

@export var max_speed : int = 14
@export var accelleration : int = 10
@export var max_distance : float = 40
@export var min_distance : float = 20

var velocity : float = 0.0

func _process(delta: float) -> void:
	if Input.is_action_pressed(\"camera_move_in\"):
		move_in(delta)
		return
	if Input.is_action_pressed(\"camera_move_out\"):
		move_out(delta)
		return
	velocity = 0
		
func move_in(delta) -> void:
	velocity += max(-accelleration * delta, -max_speed)
	position.x = max(min_distance, position.x + velocity)

func move_out(delta) -> void:
	velocity += min(accelleration * delta, max_speed)
	position.x = min(max_distance, position.x + velocity)
	
"

[sub_resource type="GDScript" id="GDScript_16uew"]
script/source = "extends Node3D

@export var target : Node3D

func _process(delta: float) -> void:
	look_at(target.position)
"

