[sub_resource type="GDScript" id="GDScript_x670l"]
script/source = "extends Node3D

@onready var rotation_x = $CameraHorizontal/CameraVertical/CameraTranslation/CameraLookat
@onready var camera = $CameraHorizontal/CameraVertical/CameraTranslation/CameraLookat/WorldCamera

var rotate_keys_speed = 1.5
var rotate_keys_target: float
var zoom_speed = 3.0
var zoom_target: float
var min_zoom = -20.0
var max_zoom = 20.0
var mouse_sensitivity = 0.2

func _ready() -> void:
	rotate_keys_target = rotation_degrees.y
	zoom_target = camera.position.z
	
	
func _unhandled_input(event: InputEvent) -> void:
	if event is InputEventMouseMotion and Input.is_action_pressed(\"rotate\") and Modes.current_mode == Enums.GameplayMode.MAP:
		
		rotate_keys_target -= event.relative.x * mouse_sensitivity
		rotation_x.rotation_degrees.x -= event.relative.y * mouse_sensitivity
		rotation_x.rotation_degrees.x = clamp(rotation_x.rotation_degrees.x, 0, 0)

func _process(delta: float) -> void:
	if Modes.current_mode == Enums.GameplayMode.MAP:
		if Input.is_action_just_pressed(\"rotate\"):
			Input.set_mouse_mode(Input.MOUSE_MODE_CAPTURED)
		if Input.is_action_just_released(\"rotate\"):
			Input.set_mouse_mode(Input.MOUSE_MODE_VISIBLE)
			
		var zoom_dir = (int(Input.is_action_just_released(\"camera_move_out\")) -
						int(Input.is_action_just_released(\"camera_move_in\")))
						
		zoom_target += zoom_dir * zoom_speed
		
		rotation_degrees.y = lerp(rotation_degrees.y, rotate_keys_target, 0.10)
		camera.position.z = lerp(camera.position.z, zoom_target, 0.10)
		zoom_target = clamp(zoom_target, -25, 15)
	else:
		Input.set_mouse_mode(Input.MOUSE_MODE_VISIBLE)
"

[sub_resource type="GDScript" id="GDScript_s3n1p"]
script/source = "extends Node3D

@export var max_speed : int = 14
@export var accelleration : int = 10
@export var velocity_decay : int = 6

var velocity : float = 0.0

func _process(delta: float) -> void:
	
	if Input.is_action_pressed(\"camera_move_left\") and Modes.current_mode == Enums.GameplayMode.MAP:
		velocity += -accelleration * delta
	elif Input.is_action_pressed(\"camera_move_right\") and Modes.current_mode == Enums.GameplayMode.MAP:
		velocity += accelleration * delta
	else:
		if abs(velocity) <= 0.3:
			velocity = 0
		else:
			if velocity > 0:
				velocity -= velocity_decay * delta
			else:
				velocity += velocity_decay * delta
	velocity = clampf(velocity, -max_speed, max_speed)
	rotation.y = deg_to_rad(rad_to_deg(rotation.y) + velocity)
"

[sub_resource type="GDScript" id="GDScript_js7sh"]
script/source = "extends Node3D

@export var max_speed : int = 14
@export var accelleration : int = 10
@export var velocity_decay : int = 6
@export var max_height : float = 60
@export var min_height : float = -60

var velocity : float = 0.0

func _process(delta: float) -> void:
	if Input.is_action_pressed(\"camera_move_up\") and Modes.current_mode == Enums.GameplayMode.MAP:
		velocity += accelleration * delta
	elif Input.is_action_pressed(\"camera_move_down\") and Modes.current_mode == Enums.GameplayMode.MAP:
		velocity += -accelleration * delta
	else:
		if abs(velocity) <= 0.3:
			velocity = 0
		else:
			if velocity > 0:
				velocity -= velocity_decay * delta
			else:
				velocity += velocity_decay * delta
	velocity = clampf(velocity, -max_speed, max_speed)
	rotation.z = clamp(
		deg_to_rad(rad_to_deg(rotation.z) + velocity), 
		deg_to_rad(min_height), 
		deg_to_rad(max_height))
"

[sub_resource type="GDScript" id="GDScript_d1xcf"]
script/source = "extends Node3D

@export var max_speed : int = 14
@export var accelleration : int = 10
@export var max_distance : float = 40
@export var min_distance : float = 20
@export var velocity_decay : int = 16

var velocity : float = 0.0

func _process(delta: float) -> void:
	if Input.is_action_pressed(\"camera_move_in\") and Modes.current_mode == Enums.GameplayMode.MAP:
		velocity += -accelleration * delta
	elif Input.is_action_pressed(\"camera_move_out\") and Modes.current_mode == Enums.GameplayMode.MAP:
		velocity += accelleration * delta
	else:
		if abs(velocity) <= 0.3:
			velocity = 0
		else:
			if velocity > 0:
				velocity -= velocity_decay * delta
			else:
				velocity += velocity_decay * delta
	velocity = clamp(velocity, -max_speed, max_speed)
	position.x = clamp(position.x + velocity, min_distance, max_distance)
"

