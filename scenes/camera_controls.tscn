[sub_resource type="GDScript" id="GDScript_jtt53"]
script/source = "extends Camera3D

signal camera_transition_started
signal camera_transition_ended

var location_cameras : Dictionary[String, Camera3D]
var default_fov : float

func _ready() -> void:
	var location_camera_node = get_tree().get_root().find_child(\"LocationCameras\", true, false)
	if location_camera_node:
		for child_camera in location_camera_node.get_children():
			location_cameras[child_camera.name] = child_camera
	default_fov = fov

func tween_to_location(new_location : Location, duration : float = 1.0) -> void:
	assert(not location_cameras.is_empty())
	assert(location_cameras.has(new_location.location_id))
	camera_transition_started.emit()
	var target_camera = location_cameras[new_location.location_id]
	var tween = create_tween()
	tween.set_parallel(true)
	tween.set_ease(Tween.EASE_IN_OUT)
	tween.set_trans(Tween.TRANS_CUBIC)
	tween.tween_property(self, \"global_position\", target_camera.global_position, duration).from(global_position)
	tween.tween_property(self, \"global_rotation\", target_camera.global_rotation, duration).from(global_rotation)
	tween.tween_property(self, \"fov\", target_camera.fov, duration).from(fov)
	await tween.finished
	camera_transition_ended.emit()

func tween_to_map(duration : float = 1.0) -> void:
	camera_transition_started.emit()
	var tween = create_tween()
	tween.set_parallel(true)
	tween.set_ease(Tween.EASE_IN_OUT)
	tween.set_trans(Tween.TRANS_CUBIC)
	tween.tween_property(self, \"position\", Vector3(), duration).from(position)
	tween.tween_property(self, \"rotation\", Vector3(), duration).from(rotation)
	tween.tween_property(self, \"fov\", default_fov, duration).from(fov)
	await tween.finished
	camera_transition_ended.emit()
"

